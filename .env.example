# Configuracao compartilhada para minerador e gateway
KAFKA_BROKER=localhost:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=gateway-visualizacao
KAFKA_TOPIC_TRANSACTIONS=transactions
KAFKA_TOPIC_BLOCKS=blocks

# Minerador
MINER_DIFFICULTY=3

# Gateway
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_RECONNECT_SECONDS=5
CORS_ORIGINS=http://localhost:4200
