KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=gateway-visualizacao
KAFKA_TOPIC_BLOCKS=blockchain.blocks
KAFKA_TOPIC_TRANSACTIONS=transactions_topic
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_RECONNECT_SECONDS=5

# Seguranca Kafka
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=usuario
# KAFKA_SASL_PASSWORD=senha

# Gateway
CORS_ORIGINS=http://localhost:4200
SNAPSHOT_MAX_BLOCKS=2000
CLIENT_QUEUE_SIZE=500
HEARTBEAT_SECONDS=60
LOG_LEVEL=INFO
